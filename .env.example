DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autend
REDIS_URL=redis://localhost:6379

POSTGRES_DB=autend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_URL=http://localhost:3000

ACCESS_TOKEN_SECRET=replace-with-a-random-64-char-secret
REFRESH_TOKEN_SECRET=replace-with-another-random-64-char-secret
TOKEN_HASH_SECRET=replace-with-a-third-random-64-char-secret

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=replace-with-mailtrap-user
SMTP_PASSWORD=replace-with-mailtrap-password
SMTP_FROM_EMAIL=no-reply@ajudaai.local
SMTP_FROM_NAME=AjudaAI

GOOGLE_OAUTH_CLIENT_ID=replace-with-real-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-real-google-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=10
EMAIL_VERIFICATION_TTL_MINUTES=1440
GOOGLE_OAUTH_STATE_TTL_MINUTES=10
REGISTER_EMAIL_RESEND_COOLDOWN_SECONDS=90

LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
REGISTER_RATE_LIMIT_MAX_ATTEMPTS=5
REFRESH_RATE_LIMIT_MAX_ATTEMPTS=10
RATE_LIMIT_WINDOW_SECONDS=60
