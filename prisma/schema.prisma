generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum SessionRevocationReason {
  USER_LOGOUT
  ROTATED
  REUSE_DETECTED
  SECURITY_EVENT
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique @db.VarChar(320)
  name              String           @db.VarChar(120)
  companyName       String?          @db.VarChar(120)
  passwordHash      String?          @db.Text
  passwordUpdatedAt DateTime?
  emailVerifiedAt   DateTime?
  status            UserStatus       @default(ACTIVE)
  lastLoginAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  oauthAccounts     OAuthAccount[]
  authSessions      AuthSession[]
  auditEvents       AuthAuditEvent[]

  @@index([createdAt])
}

model PendingRegistration {
  id                         String   @id @default(cuid())
  email                      String   @unique @db.VarChar(320)
  name                       String   @db.VarChar(120)
  companyName                String?  @db.VarChar(120)
  passwordHash               String   @db.Text
  verificationTokenHash      String   @unique @db.Char(64)
  verificationTokenExpiresAt DateTime
  resendAvailableAt          DateTime @default(now())
  attemptCount               Int      @default(1)
  consumedAt                 DateTime?
  requestedFromIp            String?  @db.VarChar(64)
  requestedUserAgent         String?  @db.VarChar(512)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([verificationTokenExpiresAt])
}

model OAuthAccount {
  id                  String   @id @default(cuid())
  provider            String   @db.VarChar(40)
  providerAccountId   String   @db.VarChar(191)
  providerEmail       String?  @db.VarChar(320)
  providerDisplayName String?  @db.VarChar(191)
  providerAvatarUrl   String?  @db.VarChar(2048)
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastUsedAt          DateTime?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model OAuthAuthorizationState {
  id                String   @id @default(cuid())
  provider          String   @db.VarChar(40)
  stateHash         String   @unique @db.Char(64)
  nonceHash         String   @db.Char(64)
  redirectPath      String   @db.VarChar(2048)
  expiresAt         DateTime
  consumedAt        DateTime?
  requestedFromIp   String?  @db.VarChar(64)
  requestedUserAgent String? @db.VarChar(512)
  createdAt         DateTime @default(now())

  @@index([expiresAt])
}

model AuthSession {
  id                String                   @id @default(cuid())
  familyId          String                   @db.VarChar(191)
  userId            String
  refreshTokenHash  String                   @unique @db.Char(64)
  parentSessionId   String?                  @db.VarChar(191)
  replacedBySessionId String?                @db.VarChar(191)
  ipAddress         String?                  @db.VarChar(64)
  userAgent         String?                  @db.VarChar(512)
  lastUsedAt        DateTime?
  expiresAt         DateTime
  revokedAt         DateTime?
  revokedReason     SessionRevocationReason?
  reuseDetectedAt   DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([parentSessionId])
}

model AuthAuditEvent {
  id         String   @id @default(cuid())
  userId      String?
  email       String? @db.VarChar(320)
  eventType   String  @db.VarChar(80)
  ipAddress   String? @db.VarChar(64)
  userAgent   String? @db.VarChar(512)
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}
